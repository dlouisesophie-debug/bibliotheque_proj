class BibliothequeAdminSite(admin.AdminSite):
    site_header = "Bibliothèque Management System"
    site_title = "Admin Bibliothèque"
    index_title = "Dashboard de Gestion de la Bibliothèque"
    
    def index(self, request, extra_context=None):
        total_livres = Livre.objects.count()
        livres_disponibles = Livre.objects.filter(disponible=True).count()
        emprunts_actifs = Emprunt.objects.filter(retourne=False).count()
        total_auteurs = Auteur.objects.count()
        
        extra_context = extra_context or {}
        extra_context.update({
            'total_livres': total_livres,
            'livres_disponibles': livres_disponibles,
            'emprunts_actifs': emprunts_actifs,
            'total_auteurs': total_auteurs,
        })
        
        return super().index(request, extra_context)


admin_site = BibliothequeAdminSite(name='myadmin')


@admin.register(Auteur, site=admin_site)
class AuteurAdmin(admin.ModelAdmin):
    list_display = ('id', 'nom', 'nationalite', 'nombre_livres', 'date_creation')
    list_display_links = ('nom',)
    list_filter = ('nationalite', 'date_creation')
    search_fields = ('nom', 'biographie', 'nationalite')
    list_per_page = 20
    ordering = ('nom',)
    list_editable = ('nationalite',)
    
    fieldsets = (
        ('Informations personnelles', {
            'fields': ('nom', 'nationalite')
        }),
        ('Biographie', {
            'fields': ('biographie',),
            'classes': ('collapse',)
        }),
        ('Métadonnées', {
            'fields': ('date_creation',),
            'classes': ('collapse',)
        }),
    )
    
    readonly_fields = ('date_creation',)
    actions = ['exporter_selectionnes']
    
    def nombre_livres(self, obj):
        count = obj.livres.count()
        url = reverse('admin:api_livre_changelist') + f'?auteur__id={obj.id}'
        return format_html('<a href="{}">{} livre(s)</a>', url, count)
    nombre_livres.short_description = 'Nombre de livres'
    
    def exporter_selectionnes(self, request, queryset):
        import csv
        from django.http import HttpResponse
        
        response = HttpResponse(content_type='text/csv')
        response['Content-Disposition'] = 'attachment; filename="auteurs_export.csv"'
        
        writer = csv.writer(response)
        writer.writerow(['ID', 'Nom', 'Nationalité', 'Biographie', 'Date création'])
        
        for auteur in queryset:
            writer.writerow([auteur.id, auteur.nom, auteur.nationalite, 
                           auteur.biographie, auteur.date_creation])
        
        return response
    exporter_selectionnes.short_description = "Exporter les auteurs sélectionnés en CSV"


@admin.register(Livre, site=admin_site)
class LivreAdmin(admin.ModelAdmin):
    list_display = ('titre', 'auteur_lien', 'categorie', 'annee_publication', 
                   'isbn', 'disponible', 'disponible_badge', 'statut_emprunt')
    list_filter = ('categorie', 'disponible', 'annee_publication', 'auteur')
    search_fields = ('titre', 'isbn', 'auteur__nom')
    list_per_page = 20
    ordering = ('-annee_publication', 'titre')
    list_editable = ('disponible',)
    
    fieldsets = (
        ('Informations principales', {
            'fields': ('titre', 'auteur', 'categorie', 'isbn')
        }),
        ('Détails', {
            'fields': ('annee_publication', 'disponible'),
            'classes': ('wide',)
        }),
        ('Métadonnées', {
            'fields': ('date_creation',),
            'classes': ('collapse',)
        }),
    )
    
    readonly_fields = ('date_creation',)
    autocomplete_fields = ('auteur',)
    
    def get_queryset(self, request):
        return super().get_queryset(request).select_related('auteur')
    
    def auteur_lien(self, obj):
        url = reverse('admin:api_auteur_change', args=[obj.auteur.id])
        return format_html('<a href="{}">{}</a>', url, obj.auteur.nom)
    auteur_lien.short_description = 'Auteur'
    
    def disponible_badge(self, obj):
        if obj.disponible:
            return format_html('<span style="color: green; font-weight: bold;">✓ Disponible</span>')
        return format_html('<span style="color: red; font-weight: bold;">✗ Emprunté</span>')
    disponible_badge.short_description = 'Statut badge'
    
    def statut_emprunt(self, obj):
        emprunts_actifs = obj.emprunts.filter(retourne=False)
        if emprunts_actifs.exists():
            return format_html(
                '<span style="color: orange;">Emprunté par {}</span>',
                emprunts_actifs.first().utilisateur.username
            )
        return format_html('<span style="color: gray;">-</span>')
    statut_emprunt.short_description = 'Emprunt actuel'
    
    actions = ['marquer_disponible', 'marquer_indisponible', 'exporter_csv']
    
    def marquer_disponible(self, request, queryset):
        queryset.update(disponible=True)
        self.message_user(request, f"{queryset.count()} livre(s) marqué(s) disponible(s)")
    marquer_disponible.short_description = "Marquer comme disponible"
    
    def marquer_indisponible(self, request, queryset):
        queryset.update(disponible=False)
        self.message_user(request, f"{queryset.count()} livre(s) marqué(s) indisponible(s)")
    marquer_indisponible.short_description = "Marquer comme indisponible"
    
    def exporter_csv(self, request, queryset):
        import csv
        from django.http import HttpResponse
        
        response = HttpResponse(content_type='text/csv')
        response['Content-Disposition'] = 'attachment; filename="livres_export.csv"'
        
        writer = csv.writer(response)
        writer.writerow(['Titre', 'Auteur', 'ISBN', 'Catégorie', 'Année', 'Disponible'])
        
        for livre in queryset:
            writer.writerow([livre.titre, livre.auteur.nom, livre.isbn, 
                           livre.categorie, livre.annee_publication, 
                           'Oui' if livre.disponible else 'Non'])
        
        return response
    exporter_csv.short_description = "Exporter en CSV"


@admin.register(Emprunt, site=admin_site)
class EmpruntAdmin(admin.ModelAdmin):
    list_display = ('id', 'livre_lien', 'utilisateur', 'date_emprunt', 
                   'date_retour', 'retourne_badge')
    list_filter = ('retourne', 'date_emprunt')
    search_fields = ('utilisateur__username', 'livre__titre')
    list_per_page = 20
    ordering = ('-date_emprunt',)
    readonly_fields = ('date_emprunt',)
    
    fieldsets = (
        ('Informations de l\'emprunt', {
            'fields': ('livre', 'utilisateur', 'date_emprunt', 'date_retour')
        }),
        ('Statut', {
            'fields': ('retourne',),
        }),
    )
    
    def livre_lien(self, obj):
        url = reverse('admin:api_livre_change', args=[obj.livre.id])
        return format_html('<a href="{}">{}</a>', url, obj.livre.titre)
    livre_lien.short_description = 'Livre'
    
    def retourne_badge(self, obj):
        if obj.retourne:
            return format_html('<span style="color: green;">✓ Retourné</span>')
        return format_html('<span style="color: red;">✗ En cours</span>')
    retourne_badge.short_description = 'Statut'
    
    actions = ['marquer_retourne']
    
    def marquer_retourne(self, request, queryset):
        for emprunt in queryset:
            if not emprunt.retourne:
                emprunt.retourne = True
